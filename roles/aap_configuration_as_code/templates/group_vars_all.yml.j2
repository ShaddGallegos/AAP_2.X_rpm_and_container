---
# Generated by role aap_configuration_as_code
backup_dir_remote: "{{ backup_dir_remote | default('/var/tmp/aap_migration_backups') }}"
aap_controller_url: "{{ aap_controller_url | default('') }}"
aap_gateway_url: "{{ aap_gateway_url | default('') }}"
aap_hub_url: "{{ aap_hub_url | default('') }}"
validate_tls: {{ validate_tls | default(false) | bool | lower }}

# Installer defaults for rebuild
aap_installer_dir: "{{ cac_rebuild_installer_dir }}"
aap_installer_inventory: "{{ cac_rebuild_installer_inventory }}"
aap_installer_command: "{{ cac_rebuild_installer_command }}"
aap_setup_extra_args: "{{ cac_rebuild_setup_extra_args }}"
