---
- name: Recreate AAP environment from config-as-code bundle
  hosts: aap_primary
  gather_facts: true
  become: true
  vars_files:
    - ../group_vars/all.yml
  roles:
    - role: aap_installer_run
      vars:
        aap_installer_dir: "{{ '{{ aap_installer_dir }}' }}"
        aap_installer_inventory: "{{ '{{ aap_installer_inventory }}' }}"
        aap_installer_command: "{{ '{{ aap_installer_command }}' }}"
        aap_setup_extra_args: "{{ '{{ aap_setup_extra_args }}' }}"

    - role: aap_validate
