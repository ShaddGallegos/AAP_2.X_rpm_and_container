# Template: AAP 2.6 containerized -> 2.6 OpenShift installer inventory
[automationcontroller]
aap-controller-1.example.com

[automationgateway]
aap-gateway-1.example.com

[automationhub]
aap-hub-1.example.com

[all:vars]
ansible_user=ansible
ansible_become=true
ansible_ssh_private_key_file=~/.ssh/id_rsa
registry_username='{{ vault_registry_username }}'
registry_password='{{ vault_registry_password }}'
admin_password='{{ vault_aap_admin_password }}'
pg_password='{{ vault_pg_password }}'
automationhub_pg_password='{{ vault_automationhub_pg_password }}'
automationhub_admin_password='{{ vault_automationhub_admin_password }}'