# Template: AAP 2.6 RPM -> 2.7 containerized installer inventory
# Copy this file to your 2.7 installer host/path, for example:
#   /opt/aap/installer-2.7/inventory_rpm_to_containerized
# Then set group_vars/all.yml:
#   aap27_installer_inventory_rpm_to_containerized: "inventory_rpm_to_containerized"
#
# Notes:
# - Replace hostnames/IPs and secrets before use.
# - Keep values in [all:vars] aligned with your environment and Red Hat guidance.

[automationcontroller]
aap-controller-1.example.com

[automationgateway]
aap-gateway-1.example.com

[automationhub]
aap-hub-1.example.com

# Optional execution nodes in the automation mesh
#[execution_nodes]
#aap-exec-1.example.com

# Optional external database host (if not managed by installer)
#[database]
#aap-db-1.example.com

[all:vars]
# Core access
ansible_user=ansible
ansible_become=true
ansible_ssh_private_key_file=~/.ssh/id_rsa

# Containerized install settings (example values; tune as needed)
#registry_url=registry.redhat.io
registry_username='{{ vault_registry_username }}'
registry_password='{{ vault_registry_password }}'

# Platform credentials (store securely, use Ansible Vault in real usage)
admin_password='{{ vault_aap_admin_password }}'
pg_password='{{ vault_pg_password }}'
automationhub_pg_password='{{ vault_automationhub_pg_password }}'
automationhub_admin_password='{{ vault_automationhub_admin_password }}'
