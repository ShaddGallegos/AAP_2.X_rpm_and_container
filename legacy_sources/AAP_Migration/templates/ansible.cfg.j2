[defaults]
inventory = inventories/production.ini
roles_path = roles:playbooks/../roles:
collections_paths = ~/.ansible/collections:/usr/share/ansible/collections

stdout_callback = default

host_key_checking = True
retry_files_enabled = False
interpreter_python = auto_silent
error_on_undefined_vars = True
any_errors_fatal = True
deprecation_warnings = True
command_warnings = True

bin_ansible_callbacks = True
callbacks_enabled = ansible.posix.profile_tasks, ansible.posix.timer

# If ansible_log_path is provided during generation, use it; otherwise logs/ansible.log
log_path = {{ ansible_log_path | default('logs/ansible.log') }}
display_failed_stderr = True
timeout = 15

[callback_default]
result_format = yaml

[privilege_escalation]
become = True
become_method = sudo
become_user = root
become_ask_pass = False

[inventory]
unparsed_is_failed = True

[ssh_connection]
pipelining = True
ssh_args = -o ControlMaster=auto -o ControlPersist=60s -o StrictHostKeyChecking=yes -o ServerAliveInterval=30 -o ServerAliveCountMax=5

[galaxy]
server_list = published, validated, community_galaxy

[galaxy_server.published]
url = https://console.redhat.com/api/automation-hub/content/published/
auth_url = https://sso.redhat.com/auth/realms/redhat-external/protocol/openid-connect/token
{% if redhat_automation_hub_token is defined and redhat_automation_hub_token|length > 0 %}
token = {{ redhat_automation_hub_token }}
{% else %}
# token not set; define 'redhat_automation_hub_token' to enable authenticated pulls
{% endif %}

[galaxy_server.validated]
url = https://console.redhat.com/api/automation-hub/content/validated/
auth_url = https://sso.redhat.com/auth/realms/redhat-external/protocol/openid-connect/token
{% if redhat_automation_hub_token is defined and redhat_automation_hub_token|length > 0 %}
token = {{ redhat_automation_hub_token }}
{% else %}
# token not set; define 'redhat_automation_hub_token' to enable authenticated pulls
{% endif %}

[galaxy_server.community_galaxy]
url = https://galaxy.ansible.com/
